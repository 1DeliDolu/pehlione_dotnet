@using System.Text.Json
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Pehlione</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Pehlione.styles.css" asp-append-version="true" />
</head>
<body>
<header class="ph-header">
    <div class="ph-topbar">
        <a class="ph-topbar__link" href="#" aria-label="Kampanya: %10 kupon al">
            Hol dir einen 10 %-Gutschein
        </a>
        <button type="button" class="ph-topbar__plus" aria-label="Kampanya detayini ac">
            +
        </button>
    </div>

    <nav class="navbar navbar-expand-lg ph-navbar">
        <div class="container-fluid px-3 px-lg-4">
            <a class="navbar-brand ph-brand" asp-area="" asp-controller="Home" asp-action="Index">
                <span class="ph-brand__mark">Pehlione</span>
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#phMainNav"
                    aria-controls="phMainNav" aria-expanded="false" aria-label="Menuyu ac/kapat">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="phMainNav">
                @await Component.InvokeAsync("MainNav")
                @{
                    var cartItemCount = 0;
                    var isAuth = User.Identity?.IsAuthenticated == true;
                    var accountArea = "";
                    var accountController = "Account";
                    var accountAction = "Login";

                    if (isAuth)
                    {
                        if (User.IsInRole("Admin"))
                        {
                            accountArea = "Admin";
                            accountController = "Home";
                            accountAction = "Index";
                        }
                        else if (User.IsInRole("IT"))
                        {
                            accountArea = "Staff";
                            accountController = "It";
                            accountAction = "Index";
                        }
                        else if (User.IsInRole("Purchasing"))
                        {
                            accountArea = "Staff";
                            accountController = "Purchasing";
                            accountAction = "Index";
                        }
                        else if (User.IsInRole("HR"))
                        {
                            accountArea = "Staff";
                            accountController = "Hr";
                            accountAction = "Index";
                        }
                        else if (User.IsInRole("Warehouse"))
                        {
                            accountArea = "Staff";
                            accountController = "Warehouse";
                            accountAction = "Index";
                        }
                        else if (User.IsInRole("Accounting"))
                        {
                            accountArea = "Staff";
                            accountController = "Accounting";
                            accountAction = "Index";
                        }
                        else if (User.IsInRole("Courier"))
                        {
                            accountArea = "Staff";
                            accountController = "Courier";
                            accountAction = "Index";
                        }
                        else if (User.IsInRole("Staff"))
                        {
                            accountArea = "Staff";
                            accountController = "Home";
                            accountAction = "Index";
                        }
                        else if (User.IsInRole("Customer"))
                        {
                            accountArea = "Customer";
                            accountController = "Home";
                            accountAction = "Index";
                        }
                    }
                    if (Context.Request.Cookies.TryGetValue("pehlione.cart", out var cartJson) && !string.IsNullOrWhiteSpace(cartJson))
                    {
                        try
                        {
                            using var doc = JsonDocument.Parse(cartJson);
                            if (doc.RootElement.ValueKind == JsonValueKind.Array)
                            {
                                foreach (var item in doc.RootElement.EnumerateArray())
                                {
                                    if (item.TryGetProperty("Qty", out var qtyProp) && qtyProp.TryGetInt32(out var qty))
                                        cartItemCount += Math.Clamp(qty, 1, 99);
                                }
                            }
                        }
                        catch
                        {
                            cartItemCount = 0;
                        }
                    }
                }

                <ul class="navbar-nav ms-lg-auto align-items-lg-center gap-lg-1">
                    <li class="nav-item">
                        <a class="nav-link ph-iconbtn" href="#" aria-label="Ara">
                            <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
                                <path fill="currentColor" d="M10 4a6 6 0 1 1 0 12A6 6 0 0 1 10 4m0-2a8 8 0 1 0 4.9 14.3l4.4 4.4 1.4-1.4-4.4-4.4A8 8 0 0 0 10 2z" />
                            </svg>
                        </a>
                    </li>
                    <li class="nav-item dropdown">
                        @if (isAuth)
                        {
                            <a class="nav-link ph-iconbtn dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false" aria-label="Hesabim">
                                <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
                                    <path fill="currentColor" d="M12 12a4 4 0 1 0-4-4 4 4 0 0 0 4 4zm0 2c-4.4 0-8 2.2-8 5v1h16v-1c0-2.8-3.6-5-8-5z" />
                                </svg>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow-sm">
                                <li>
                                    <a class="dropdown-item" asp-area="@accountArea" asp-controller="@accountController" asp-action="@accountAction">Dashboard</a>
                                </li>
                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <form asp-area="" asp-controller="Account" asp-action="Logout" method="post" class="px-2 py-1">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="dropdown-item text-danger">Sign out</button>
                                    </form>
                                </li>
                            </ul>
                        }
                        else
                        {
                            <a class="nav-link ph-iconbtn" asp-area="" asp-controller="Account" asp-action="Login" aria-label="Login">
                                <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
                                    <path fill="currentColor" d="M12 12a4 4 0 1 0-4-4 4 4 0 0 0 4 4zm0 2c-4.4 0-8 2.2-8 5v1h16v-1c0-2.8-3.6-5-8-5z" />
                                </svg>
                            </a>
                        }
                    </li>
                    <li class="nav-item">
                        <a class="nav-link ph-iconbtn ph-iconbtn--cart" asp-area="Customer" asp-controller="Cart" asp-action="Index" aria-label="Sepet">
                            <i class="bi bi-cart2" aria-hidden="true"></i>
                            @if (cartItemCount > 0)
                            {
                                <span class="ph-cartcount" aria-label="@($"{cartItemCount} urun sepetinizde")">
                                    @cartItemCount
                                </span>
                            }
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>
</header>

<div class="container ph-page">
    <main role="main" class="pb-3">
        @RenderBody()
    </main>
</div>

<footer class="border-top footer text-muted">
    <div class="container">
        &copy; @DateTime.UtcNow.Year - Pehlione - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
    </div>
</footer>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
