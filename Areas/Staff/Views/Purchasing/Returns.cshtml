@model IReadOnlyList<Pehlione.Models.ViewModels.Admin.OrderListItemVm>
@{
    ViewData["Title"] = "Iade / Iptal Kuyrugu";
    var query = (string?)ViewBag.Query ?? "";
}

<div class="container-fluid py-4">
    <div class="card border-0 shadow-sm rounded-4 mb-3">
        <div class="card-body p-3 d-flex flex-wrap align-items-center gap-2">
            <a class="btn btn-sm btn-outline-secondary" asp-area="Staff" asp-controller="Purchasing" asp-action="Index">Purchasing Dashboard</a>
            <a class="btn btn-sm btn-primary" asp-area="Staff" asp-controller="Purchasing" asp-action="Returns">Iade/Iptal</a>
            <a class="btn btn-sm btn-outline-secondary" asp-area="Staff" asp-controller="Inventory" asp-action="Receive">Stok Formu</a>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
            <h1 class="h3 mb-3">Iade ve Iptal Kuyrugu</h1>
            <p class="text-muted">Cancelled, Return Delivered to Seller ve Refunded siparisler buraya duser. Satin alma bu kayitlara gore yeniden giris/donus operasyonunu planlar.</p>

            @if (TempData["PurchasingSuccess"] is string ok && !string.IsNullOrWhiteSpace(ok))
            {
                <div class="alert alert-success py-2">@ok</div>
            }
            @if (TempData["PurchasingError"] is string err && !string.IsNullOrWhiteSpace(err))
            {
                <div class="alert alert-danger py-2">@err</div>
            }

            <form method="get" asp-area="Staff" asp-controller="Purchasing" asp-action="Returns" class="row g-2 mb-3">
                <div class="col-12 col-md-5">
                    <input type="text" name="q" value="@query" class="form-control" placeholder="Siparis no veya e-posta ara..." />
                </div>
                <div class="col-12 col-md-2 d-grid">
                    <button type="submit" class="btn btn-outline-primary">Filtrele</button>
                </div>
            </form>

            @if (Model.Count == 0)
            {
                <div class="alert alert-info mb-0">Iade/iptal kaydi bulunamadi.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Tarih</th>
                            <th>Musteri</th>
                            <th>Durum</th>
                            <th>Kargo</th>
                            <th>Kalem</th>
                            <th class="text-end">Tutar</th>
                            <th class="text-end">Islem</th>
                        </tr>
                        </thead>
                        <tbody>
                        @foreach (var o in Model)
                        {
                            <tr>
                                <td>#@o.Id</td>
                                <td>@o.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                                <td>@o.CustomerEmail</td>
                                <td><span class="badge text-bg-light">@o.Status</span></td>
                                <td class="small text-muted">
                                    @(string.IsNullOrWhiteSpace(o.ShippingCarrier) ? "-" : o.ShippingCarrier)
                                    @if (!string.IsNullOrWhiteSpace(o.TrackingCode))
                                    {
                                        <span class="d-block">@o.TrackingCode</span>
                                    }
                                </td>
                                <td>@o.ItemCount</td>
                                <td class="text-end fw-semibold">@o.TotalAmount.ToString("0.00") @o.Currency</td>
                                <td class="text-end">
                                    @if (o.CanRestock)
                                    {
                                        <form method="post" asp-area="Staff" asp-controller="Purchasing" asp-action="RestockReturnedOrder" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@o.Id" />
                                            <input type="hidden" name="q" value="@query" />
                                            <button type="submit" class="btn btn-sm btn-outline-success">Stoga Al</button>
                                        </form>
                                    }
                                    else if (o.IsRestocked)
                                    {
                                        <span class="badge text-bg-success">Stoga Alindi</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">-</span>
                                    }
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
