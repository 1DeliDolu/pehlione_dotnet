@model IReadOnlyList<Pehlione.Models.ViewModels.Admin.OrderListItemVm>
@{
    ViewData["Title"] = "Kargo Islem Listesi";
    var query = (string?)ViewBag.Query ?? "";
    var selectedStatus = (string?)ViewBag.Status ?? "";
    var statuses = ViewBag.Statuses as string[] ?? Array.Empty<string>();
}

<div class="container-fluid py-4">
    <div class="card border-0 shadow-sm rounded-4 mb-3">
        <div class="card-body p-3 d-flex flex-wrap align-items-center gap-2">
            <a class="btn btn-sm btn-outline-secondary" asp-area="Staff" asp-controller="Courier" asp-action="Index">Courier Dashboard</a>
            <a class="btn btn-sm btn-primary" asp-area="Staff" asp-controller="Courier" asp-action="Orders">Kargo Islem Listesi</a>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
            <h1 class="h3 mb-3">Kargo Operasyon Listesi</h1>
            <p class="text-muted">Musteriye teslim ve saticiya geri teslim akisini bu listeden yonetin.</p>

            @if (TempData["CourierSuccess"] is string success && !string.IsNullOrWhiteSpace(success))
            {
                <div class="alert alert-success py-2">@success</div>
            }
            @if (TempData["CourierError"] is string error && !string.IsNullOrWhiteSpace(error))
            {
                <div class="alert alert-danger py-2">@error</div>
            }

            <form method="get" asp-area="Staff" asp-controller="Courier" asp-action="Orders" class="row g-2 mb-3">
                <div class="col-12 col-md-5">
                    <input type="text" name="q" value="@query" class="form-control" placeholder="Siparis no veya e-posta ara..." />
                </div>
                <div class="col-12 col-md-3">
                    <select name="status" class="form-select">
                        <option value="">Tum durumlar</option>
                        @foreach (var s in statuses)
                        {
                            <option value="@s" selected="@(selectedStatus == s)">@s</option>
                        }
                    </select>
                </div>
                <div class="col-12 col-md-2 d-grid">
                    <button type="submit" class="btn btn-outline-primary">Filtrele</button>
                </div>
            </form>

            @if (Model.Count == 0)
            {
                <div class="alert alert-info mb-0">Siparis bulunamadi.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Tarih</th>
                            <th>Musteri</th>
                            <th>Durum</th>
                            <th>Kargo Islem</th>
                            <th>Kalem</th>
                            <th class="text-end">Tutar</th>
                        </tr>
                        </thead>
                        <tbody>
                        @foreach (var o in Model)
                        {
                            var nextOptions = o.NextStatusOptions ?? Array.Empty<string>();
                            var canEdit = nextOptions.Count > 0;
                            <tr>
                                <td>#@o.Id</td>
                                <td>@o.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                                <td>@o.CustomerEmail</td>
                                <td><span class="badge text-bg-light">@o.Status</span></td>
                                <td>
                                    <form method="post" asp-area="Staff" asp-controller="Courier" asp-action="UpdateStatus" class="d-flex gap-2">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@o.Id" />
                                        <input type="hidden" name="q" value="@query" />
                                        <input type="hidden" name="currentStatus" value="@selectedStatus" />
                                        <select name="status" class="form-select form-select-sm" disabled="@(!canEdit)">
                                            @foreach (var option in nextOptions)
                                            {
                                                <option value="@option">@option</option>
                                            }
                                        </select>
                                        <button type="submit" class="btn btn-sm btn-outline-primary" disabled="@(!canEdit)">Kaydet</button>
                                    </form>
                                </td>
                                <td>@o.ItemCount</td>
                                <td class="text-end fw-semibold">@o.TotalAmount.ToString("0.00") @o.Currency</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
