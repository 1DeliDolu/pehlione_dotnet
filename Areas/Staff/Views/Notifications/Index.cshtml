@model Pehlione.Models.ViewModels.Staff.NotificationIndexVm
@{
    ViewData["Title"] = "Bildirimler";
}

<div class="container" style="max-width: 980px;">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <h1 class="h3 m-0">Bildirimler</h1>
        <form asp-area="Staff" asp-controller="Notifications" asp-action="MarkAllRead" method="post" class="d-inline">
            @Html.AntiForgeryToken()
            <input type="hidden" name="includeRead" value="@Model.IncludeRead" />
            <button type="submit" class="btn btn-outline-secondary">Tumunu okundu yap</button>
        </form>
    </div>

    <form method="get" asp-area="Staff" asp-controller="Notifications" asp-action="Index" class="mb-3">
        <div class="form-check">
            <input class="form-check-input" type="checkbox" id="includeRead" name="includeRead" value="true" @(Model.IncludeRead ? "checked" : "") />
            <label class="form-check-label" for="includeRead">Okunmus olanlari da goster</label>
        </div>
        <button class="btn btn-sm btn-primary mt-2" type="submit">Filtreyi uygula</button>
    </form>

    @if (Model.Items.Count == 0)
    {
        <div class="alert alert-info">Gosterilecek bildirim yok.</div>
    }
    else
    {
        <div class="list-group shadow-sm">
            @foreach (var n in Model.Items)
            {
                <div class="list-group-item">
                    <div class="d-flex justify-content-between align-items-start gap-3">
                        <div>
                            <div class="small text-muted mb-1">
                                <span class="badge text-bg-light">@n.Department</span>
                                <span>@n.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</span>
                            </div>
                            <div class="fw-semibold">@n.Title</div>
                            <div>@n.Message</div>
                            @if (!string.IsNullOrWhiteSpace(n.RelatedEntityType) && !string.IsNullOrWhiteSpace(n.RelatedEntityId))
                            {
                                <div class="small text-muted mt-1">@n.RelatedEntityType #@n.RelatedEntityId</div>
                            }
                        </div>
                        <div class="text-end">
                            @if (n.IsRead)
                            {
                                <span class="badge text-bg-success">Okundu</span>
                            }
                            else
                            {
                                <form asp-area="Staff" asp-controller="Notifications" asp-action="MarkRead" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@n.Id" />
                                    <input type="hidden" name="includeRead" value="@Model.IncludeRead" />
                                    <button type="submit" class="btn btn-sm btn-outline-primary">Okundu</button>
                                </form>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
