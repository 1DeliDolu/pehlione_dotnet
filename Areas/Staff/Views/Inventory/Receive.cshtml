@model Pehlione.Models.ViewModels.Staff.ReceiveStockVm
@{
    ViewData["Title"] = "Stok Girisi";
}

<div class="container py-4">
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-4">
            <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3">
                <div>
                    <span class="badge text-bg-primary mb-2">Inventory</span>
                    <h1 class="h3 mb-1">Stok Girisi</h1>
                    <p class="text-muted mb-0">Kategori ve urun secerek stok ekleyin. Girilen miktar mevcut stok uzerine ilave edilir.</p>
                </div>
                <div class="text-muted small">Personel paneli / Stok yonetimi</div>
            </div>
        </div>
    </div>

    @if (TempData["InventorySuccess"] is string ok && !string.IsNullOrWhiteSpace(ok))
    {
        <div class="alert alert-success shadow-sm">@ok</div>
    }

    @if (TempData["InventoryError"] is string err && !string.IsNullOrWhiteSpace(err))
    {
        <div class="alert alert-warning shadow-sm">@err</div>
    }

    <div class="row g-4">
        <div class="col-12">
            <form id="receiveForm" asp-area="Staff" asp-controller="Inventory" asp-action="Receive" method="post" class="card border-0 shadow-sm rounded-4">
                @Html.AntiForgeryToken()

                <div class="card-header bg-white border-0 pt-4 px-4">
                    <h2 class="h5 mb-1">Satin Alma Girisi</h2>
                    <p class="text-muted small mb-0">Kategori agacindan secip miktar girerek stok girisi yapin.</p>
                </div>

                <div class="card-body px-4 pb-4">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row g-3">
                        <div class="col-12">
                            <label asp-for="TopCategoryId" class="form-label fw-semibold"></label>
                            <select asp-for="TopCategoryId" asp-items="Model.TopCategoryOptions" class="form-select form-select-lg" id="topCategorySelect"></select>
                            <span asp-validation-for="TopCategoryId" class="text-danger small"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="SubCategoryId" class="form-label fw-semibold"></label>
                            <select asp-for="SubCategoryId" class="form-select form-select-lg" id="subCategorySelect">
                                <option value="">Seciniz</option>
                                @foreach (var c in Model.SubCategoryOptions)
                                {
                                    if (Model.SubCategoryId.HasValue && c.Value == Model.SubCategoryId.Value.ToString())
                                    {
                                        <option value="@c.Value" selected>@c.Text</option>
                                    }
                                    else
                                    {
                                        <option value="@c.Value">@c.Text</option>
                                    }
                                }
                            </select>
                            <span asp-validation-for="SubCategoryId" class="text-danger small"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="SubSubCategoryId" class="form-label fw-semibold"></label>
                            <select asp-for="SubSubCategoryId" class="form-select form-select-lg" id="subSubCategorySelect">
                                <option value="">Seciniz</option>
                                @foreach (var c in Model.SubSubCategoryOptions)
                                {
                                    if (Model.SubSubCategoryId.HasValue && c.Value == Model.SubSubCategoryId.Value.ToString())
                                    {
                                        <option value="@c.Value" selected>@c.Text</option>
                                    }
                                    else
                                    {
                                        <option value="@c.Value">@c.Text</option>
                                    }
                                }
                            </select>
                            <span asp-validation-for="SubSubCategoryId" class="text-danger small"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="ProductId" class="form-label fw-semibold"></label>
                            <select asp-for="ProductId" class="form-select form-select-lg" id="productSelect">
                                @foreach (var p in Model.ProductOptions)
                                {
                                    if (p.Value == Model.ProductId.ToString())
                                    {
                                        <option value="@p.Value" selected>@p.Text</option>
                                    }
                                    else
                                    {
                                        <option value="@p.Value">@p.Text</option>
                                    }
                                }
                            </select>
                            <span asp-validation-for="ProductId" class="text-danger small"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="Quantity" class="form-label fw-semibold"></label>
                            <input asp-for="Quantity" class="form-control form-control-lg" min="1" placeholder="Miktar giriniz" />
                            <span asp-validation-for="Quantity" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end mt-4">
                        @if (User.IsInRole("Purchasing") || User.IsInRole("Warehouse") || User.IsInRole("Admin"))
                        {
                            <button type="submit" class="btn btn-primary btn-lg px-4">Stok Artir</button>
                        }
                    </div>
                </div>
            </form>

            @if (User.IsInRole("Warehouse") || User.IsInRole("Admin"))
            {
                <form id="decreaseForm" asp-area="Staff" asp-controller="Inventory" asp-action="Decrease" method="post" class="card border-0 shadow-sm rounded-4 mt-3">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="TopCategoryId" id="decreaseTopCategoryId" value="@Model.TopCategoryId" />
                    <input type="hidden" name="SubCategoryId" id="decreaseSubCategoryId" value="@Model.SubCategoryId" />
                    <input type="hidden" name="SubSubCategoryId" id="decreaseSubSubCategoryId" value="@Model.SubSubCategoryId" />
                    <input type="hidden" name="ProductId" id="decreaseProductId" value="@Model.ProductId" />

                    <div class="card-header bg-white border-0 pt-4 px-4">
                        <h2 class="h5 mb-1">Warehouse Cikis Formu</h2>
                        <p class="text-muted small mb-0">Secili urun stok miktarini dusurun. Stok sifirin altina inmez.</p>
                    </div>
                    <div class="card-body px-4 pb-4">
                        <div class="row g-3">
                            <div class="col-12">
                                <label for="decreaseQuantity" class="form-label fw-semibold">Azaltilacak Adet</label>
                                <input id="decreaseQuantity" name="Quantity" type="number" min="1" value="1" class="form-control form-control-lg" />
                            </div>
                        </div>
                        <div class="d-flex justify-content-end mt-4">
                            <button type="submit" class="btn btn-outline-danger btn-lg px-4">Stok Azalt</button>
                        </div>
                    </div>
                </form>
            }
        </div>
        <div class="col-12">
            @if (User.IsInRole("IT") || User.IsInRole("Admin"))
            {
                <form asp-area="Staff" asp-controller="Inventory" asp-action="DeleteProduct" method="post" class="card border-0 shadow-sm rounded-4">
                    @Html.AntiForgeryToken()

                    <div class="card-header bg-white border-0 pt-4 px-4">
                        <h2 class="h5 mb-1">IT Islem: Urun Sil</h2>
                        <p class="text-muted small mb-0">Yalnizca yetkili kullanicilar bu islemi yapabilir.</p>
                    </div>

                    <div class="card-body px-4 pb-4">
                        <div class="mb-3">
                            <label class="form-label fw-semibold" for="productIdDelete">Urun</label>
                            <select id="productIdDelete" name="productId" class="form-select form-select-lg">
                                @foreach (var p in Model.AllProducts)
                                {
                                    <option value="@p.ProductId">@p.Name (@p.Sku)</option>
                                }
                            </select>
                        </div>

                        <div class="d-flex justify-content-end">
                            <button type="submit" class="btn btn-outline-danger btn-lg px-4">Urunu Sil</button>
                        </div>
                    </div>
                </form>
            }
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 mt-4">
        <div class="card-header bg-white border-0 pt-4 px-4">
            <h2 class="h5 mb-1">Guncel Stok Durumu</h2>
            <p class="text-muted small mb-0">Urunlerin mevcut stok miktarlari</p>
        </div>
        <div class="card-body px-4 pb-4">
            <div class="row g-2 mb-3">
                <div class="col-12 col-md-6">
                    <input id="stockSearchInput" type="search" class="form-control" placeholder="Urun veya SKU ara..." />
                </div>
            </div>
            @if (Model.StockSnapshots.Count == 0)
            {
                <div class="alert alert-info mb-0">Stok verisi yok.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0" id="stockSnapshotTable">
                        <thead class="table-light">
                            <tr>
                                <th>Urun</th>
                                <th>SKU</th>
                                <th class="text-end">Stok</th>
                                <th class="text-end">Islem</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var s in Model.StockSnapshots)
                            {
                                <tr>
                                    <td>@s.ProductName</td>
                                    <td><code>@s.Sku</code></td>
                                    <td class="text-end fw-semibold">@s.Quantity</td>
                                    <td class="text-end">
                                        <button type="button"
                                                class="btn btn-sm btn-outline-primary js-stock-edit"
                                                data-product-id="@s.ProductId"
                                                data-qty="@s.Quantity">
                                            Edit
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 mt-4">
        <div class="card-header bg-white border-0 pt-4 px-4">
            <h2 class="h5 mb-1">Son Stok Hareketleri</h2>
            <p class="text-muted small mb-0">En son stok giris ve cikis kayitlari</p>
        </div>
        <div class="card-body px-4 pb-4">
            @if (Model.RecentMovements.Count == 0)
            {
                <div class="alert alert-info mb-0">Hareket kaydi yok.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Tarih</th>
                                <th>Urun</th>
                                <th>Tip</th>
                                <th class="text-end">Adet</th>
                                <th>Aciklama</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var m in Model.RecentMovements)
                            {
                                <tr>
                                    <td>@m.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</td>
                                    <td>@m.ProductName <code>@m.Sku</code></td>
                                    <td>
                                        @if (m.Type == "In")
                                        {
                                            <span class="badge text-bg-success">In</span>
                                        }
                                        else
                                        {
                                            <span class="badge text-bg-danger">Out</span>
                                        }
                                    </td>
                                    <td class="text-end fw-semibold">@m.Quantity</td>
                                    <td>@(string.IsNullOrWhiteSpace(m.Reason) ? "-" : m.Reason)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            const topCategorySelect = document.getElementById('topCategorySelect');
            const subCategorySelect = document.getElementById('subCategorySelect');
            const subSubCategorySelect = document.getElementById('subSubCategorySelect');
            const productSelect = document.getElementById('productSelect');
            const quantityInput = document.getElementById('Quantity');
            const decreaseQuantityInput = document.getElementById('decreaseQuantity');
            const decreaseTopCategoryInput = document.getElementById('decreaseTopCategoryId');
            const decreaseSubCategoryInput = document.getElementById('decreaseSubCategoryId');
            const decreaseSubSubCategoryInput = document.getElementById('decreaseSubSubCategoryId');
            const decreaseProductInput = document.getElementById('decreaseProductId');
            const receiveForm = document.getElementById('receiveForm');
            const stockSearchInput = document.getElementById('stockSearchInput');
            const stockSnapshotTable = document.getElementById('stockSnapshotTable');
            if (!topCategorySelect || !subCategorySelect || !subSubCategorySelect || !productSelect || !quantityInput) return;

            const allCategories = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AllCategories));
            const allProducts = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AllProducts));

            function fillOptions(select, items, valueField, textField, selectedValue, includeEmpty) {
                select.innerHTML = '';
                if (includeEmpty) {
                    const emptyOption = document.createElement('option');
                    emptyOption.value = '';
                    emptyOption.textContent = 'Seciniz';
                    select.appendChild(emptyOption);
                }
                for (const item of items) {
                    const option = document.createElement('option');
                    option.value = String(item[valueField]);
                    option.textContent = item[textField];
                    if (String(item[valueField]) === String(selectedValue || '')) {
                        option.selected = true;
                    }
                    select.appendChild(option);
                }
                if (select.options.length > 0 && select.selectedIndex < 0) {
                    select.selectedIndex = 0;
                }
            }

            function loadSubCategories(parentId, targetSelect, selectedValue) {
                if (!parentId) {
                    fillOptions(targetSelect, [], 'value', 'text', '', true);
                    return;
                }
                const items = allCategories
                    .filter(c => c.ParentCategoryId === parentId)
                    .sort((a, b) => (a.SortOrder - b.SortOrder) || (a.Name || '').localeCompare(b.Name || ''))
                    .map(c => ({ value: c.CategoryId, text: c.Name }));
                fillOptions(targetSelect, items, 'value', 'text', selectedValue, true);
            }

            function getDescendantCategoryIds(rootId) {
                const result = new Set();
                if (!rootId) return result;
                const queue = [rootId];
                result.add(rootId);
                while (queue.length > 0) {
                    const current = queue.shift();
                    for (const c of allCategories) {
                        if (c.ParentCategoryId === current && !result.has(c.CategoryId)) {
                            result.add(c.CategoryId);
                            queue.push(c.CategoryId);
                        }
                    }
                }
                return result;
            }

            function loadProducts(categoryId, selectedValue) {
                if (!categoryId) {
                    fillOptions(productSelect, [], 'value', 'text', '', false);
                    return;
                }
                const allowed = getDescendantCategoryIds(categoryId);
                const items = allProducts
                    .filter(p => allowed.has(p.CategoryId))
                    .sort((a, b) => (a.Name || '').localeCompare(b.Name || ''))
                    .map(p => ({ value: p.ProductId, text: `${p.Name} (${p.Sku})` }));
                fillOptions(productSelect, items, 'value', 'text', selectedValue, false);
            }

            function getCategoryChain(categoryId) {
                const byId = new Map(allCategories.map(x => [x.CategoryId, x]));
                const chain = [];
                let current = byId.get(categoryId);
                while (current) {
                    chain.push(current.CategoryId);
                    if (!current.ParentCategoryId) break;
                    current = byId.get(current.ParentCategoryId);
                }
                return chain.reverse();
            }

            function fillFormFromProduct(productId, qty) {
                const product = allProducts.find(p => p.ProductId === productId);
                if (!product) return;

                const chain = getCategoryChain(product.CategoryId);
                const topId = chain[0] || 0;
                const subId = chain[1] || '';
                const subSubId = chain[2] || '';

                topCategorySelect.value = String(topId);
                loadSubCategories(topId, subCategorySelect, String(subId || ''));
                loadSubCategories(parseInt(subCategorySelect.value || '0', 10), subSubCategorySelect, String(subSubId || ''));

                const selectedNode = parseInt(subSubCategorySelect.value || subCategorySelect.value || topCategorySelect.value || '0', 10);
                loadProducts(selectedNode, String(productId));

                quantityInput.value = String(qty);
                if (decreaseQuantityInput) {
                    decreaseQuantityInput.value = String(qty > 0 ? qty : 1);
                }
                syncDecreaseFormContext();
                receiveForm?.scrollIntoView({ behavior: 'smooth', block: 'start' });
                quantityInput.focus();
            }

            function syncDecreaseFormContext() {
                if (!decreaseProductInput || !decreaseTopCategoryInput || !decreaseSubCategoryInput || !decreaseSubSubCategoryInput) return;

                decreaseTopCategoryInput.value = topCategorySelect.value || '';
                decreaseSubCategoryInput.value = subCategorySelect.value || '';
                decreaseSubSubCategoryInput.value = subSubCategorySelect.value || '';
                decreaseProductInput.value = productSelect.value || '';
            }

            function syncProducts() {
                const topId = parseInt(topCategorySelect.value || '0', 10);
                const subId = parseInt(subCategorySelect.value || '0', 10);
                const subSubId = parseInt(subSubCategorySelect.value || '0', 10);
                const selectedNode = subSubId || subId || topId;
                const currentProduct = productSelect.value || '';
                loadProducts(selectedNode, currentProduct);
            }

            topCategorySelect.addEventListener('change', function () {
                loadSubCategories(parseInt(topCategorySelect.value || '0', 10), subCategorySelect, '');
                loadSubCategories(parseInt(subCategorySelect.value || '0', 10), subSubCategorySelect, '');
                syncProducts();
                syncDecreaseFormContext();
            });

            subCategorySelect.addEventListener('change', function () {
                loadSubCategories(parseInt(subCategorySelect.value || '0', 10), subSubCategorySelect, '');
                syncProducts();
                syncDecreaseFormContext();
            });

            subSubCategorySelect.addEventListener('change', function () {
                syncProducts();
                syncDecreaseFormContext();
            });

            productSelect.addEventListener('change', function () {
                syncDecreaseFormContext();
            });

            (function initialize() {
                loadSubCategories(parseInt(topCategorySelect.value || '0', 10), subCategorySelect, '@(Model.SubCategoryId?.ToString() ?? "")');
                loadSubCategories(parseInt(subCategorySelect.value || '0', 10), subSubCategorySelect, '@(Model.SubSubCategoryId?.ToString() ?? "")');
                loadProducts(parseInt(subSubCategorySelect.value || subCategorySelect.value || topCategorySelect.value || '0', 10), '@Model.ProductId');
                syncDecreaseFormContext();
            })();

            document.querySelectorAll('.js-stock-edit').forEach(btn => {
                btn.addEventListener('click', function () {
                    const productId = parseInt(btn.getAttribute('data-product-id') || '0', 10);
                    const qty = parseInt(btn.getAttribute('data-qty') || '1', 10);
                    if (productId > 0) {
                        fillFormFromProduct(productId, qty > 0 ? qty : 1);
                    }
                });
            });

            if (stockSearchInput && stockSnapshotTable) {
                const rows = Array.from(stockSnapshotTable.querySelectorAll('tbody tr'));
                stockSearchInput.addEventListener('input', function () {
                    const q = (stockSearchInput.value || '').toLowerCase().trim();
                    rows.forEach(row => {
                        const text = (row.textContent || '').toLowerCase();
                        row.style.display = !q || text.includes(q) ? '' : 'none';
                    });
                });
            }
        })();
    </script>
}
