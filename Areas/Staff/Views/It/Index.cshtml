@model Pehlione.Models.ViewModels.Staff.DepartmentConstraintsVm
@{
    ViewData["Title"] = "IT Kisit Yonetimi";
    var createPersonnel = (ViewData["CreatePersonnelModel"] as Pehlione.Models.ViewModels.Staff.ItCreatePersonnelVm)
        ?? new Pehlione.Models.ViewModels.Staff.ItCreatePersonnelVm();
}

<div class="container-fluid py-4">
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-4">
            <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
                <div>
                    <span class="badge text-bg-dark mb-2">IT Dashboard</span>
                    <h1 class="h3 mb-1">Departman Kisit Yonetimi</h1>
                    <p class="text-muted mb-0">Departman bazli stok girisi ve urun silme yetkilerini veritabanindan yonetin.</p>
                </div>
                <div class="text-muted small">Staff / IT</div>
            </div>
        </div>
    </div>

    @await Component.InvokeAsync("DashboardNotifications")

    @if (TempData["ItConstraintSaved"] is string ok && !string.IsNullOrWhiteSpace(ok))
    {
        <div class="alert alert-success shadow-sm">@ok</div>
    }

    <form asp-area="Staff" asp-controller="It" asp-action="Index" method="post" class="card border-0 shadow-sm rounded-4">
        @Html.AntiForgeryToken()

        <div class="card-header bg-white border-0 pt-4 px-4">
            <h2 class="h5 mb-1">Departman Ayarlari</h2>
            <p class="text-muted small mb-0">Okuma / Yazma / Silme yetkileri kaydedildiginde aninda aktif olur.</p>
        </div>

        <div class="card-body px-4 pb-4">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row g-3">
                @for (var i = 0; i < Model.Items.Count; i++)
                {
                    <div class="col-12 col-xl-4">
                        <div class="border rounded-4 p-3 h-100 bg-light-subtle">
                            <input asp-for="Items[i].Department" type="hidden" />

                            <div class="mb-3">
                                <label class="form-label fw-semibold">Departman</label>
                                <input class="form-control" value="@Model.Items[i].Department" disabled />
                            </div>

                            <div class="form-check form-switch mb-2">
                                <input asp-for="Items[i].CanReadStock" class="form-check-input" />
                                <label asp-for="Items[i].CanReadStock" class="form-check-label"></label>
                            </div>

                            <div class="form-check form-switch mb-2">
                                <input asp-for="Items[i].CanIncreaseStock" class="form-check-input" />
                                <label asp-for="Items[i].CanIncreaseStock" class="form-check-label"></label>
                            </div>

                            <div class="form-check form-switch mb-3">
                                <input asp-for="Items[i].CanDeleteStock" class="form-check-input" />
                                <label asp-for="Items[i].CanDeleteStock" class="form-check-label"></label>
                            </div>

                            <div>
                                <label asp-for="Items[i].MaxReceiveQuantity" class="form-label fw-semibold"></label>
                                <input asp-for="Items[i].MaxReceiveQuantity" type="number" min="1" class="form-control" placeholder="Sinirsiz icin bos birakin" />
                                <span asp-validation-for="Items[i].MaxReceiveQuantity" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="d-flex justify-content-end mt-4">
                <button type="submit" class="btn btn-primary btn-lg px-4">Kaydet</button>
            </div>
        </div>
    </form>

    <form asp-area="Staff" asp-controller="It" asp-action="CreatePersonnel" method="post" class="card border-0 shadow-sm rounded-4 mt-4">
        @Html.AntiForgeryToken()
        <div class="card-header bg-white border-0 pt-4 px-4">
            <h2 class="h5 mb-1">Personel Girisi ve Sifre Olusturma</h2>
            <p class="text-muted small mb-0">IT birimi buradan yeni personel hesabi acabilir.</p>
        </div>
        <div class="card-body px-4 pb-4">
            <div class="row g-3">
                <div class="col-12 col-lg-4">
                    <label class="form-label fw-semibold">Personel E-posta</label>
                    <input name="Email" value="@createPersonnel.Email" type="email" class="form-control" />
                </div>
                <div class="col-12 col-lg-4">
                    <label class="form-label fw-semibold">Gecici Sifre</label>
                    <input name="Password" value="@createPersonnel.Password" type="text" class="form-control" />
                </div>
                <div class="col-12 col-lg-4">
                    <label class="form-label fw-semibold">Rol</label>
                    <select name="Role" class="form-select">
                        <option value="Staff" selected="@(createPersonnel.Role == "Staff")">Staff</option>
                        <option value="Purchasing" selected="@(createPersonnel.Role == "Purchasing")">Purchasing</option>
                        <option value="Warehouse" selected="@(createPersonnel.Role == "Warehouse")">Warehouse</option>
                        <option value="IT" selected="@(createPersonnel.Role == "IT")">IT</option>
                        <option value="HR" selected="@(createPersonnel.Role == "HR")">HR</option>
                        <option value="Accounting" selected="@(createPersonnel.Role == "Accounting")">Accounting</option>
                        <option value="Courier" selected="@(createPersonnel.Role == "Courier")">Courier</option>
                        <option value="CustomerRelations" selected="@(createPersonnel.Role == "CustomerRelations")">CustomerRelations</option>
                    </select>
                </div>
            </div>
            <div class="d-flex justify-content-end mt-4">
                <button type="submit" class="btn btn-outline-primary btn-lg px-4">Personel Olustur</button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
