@model IReadOnlyList<Pehlione.Models.ViewModels.Customer.CatalogCategoryListItemVm>
@{
    ViewData["Title"] = "Katalog";
}

<div class="container" style="max-width: 980px;">
    <h1 class="h3 mb-3">Katalog</h1>

    @if (Model.Count == 0)
    {
        <div class="alert alert-info">
            Henuz aktif ana kategori yok.
        </div>
    }
    else
    {
        <div class="list-group">
            @foreach (var c in Model)
            {
                <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"
                   asp-area="Customer"
                   asp-controller="Catalog"
                   asp-action="Category"
                   asp-route-slug="@c.Slug">
                    <span>@c.Name</span>
                    <span class="text-muted"><code>@c.Slug</code></span>
                </a>
            }
        </div>
    }

    <div class="mt-3">
        <a class="btn btn-outline-secondary" asp-area="Customer" asp-controller="Home" asp-action="Index">Musteri ana sayfasi</a>
    </div>
</div>
