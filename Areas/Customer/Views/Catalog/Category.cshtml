@model Pehlione.Models.ViewModels.Customer.CatalogCategoryDetailsVm
@{
    ViewData["Title"] = Model.Category.Name;
    var query = (string?)ViewBag.Query ?? "";
    var sort = (string?)ViewBag.Sort ?? "";
    var productCount = ViewBag.ProductCount is int n ? n : Model.Products.Count;
}

<div class="container py-3 py-md-4" style="max-width: 1160px;">
    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body p-3 p-md-4">
            <div class="d-flex flex-wrap align-items-center justify-content-between gap-2">
                <div>
                    <div class="text-uppercase small text-muted mb-1">Kategori</div>
                    <h1 class="h3 m-0">@Model.Category.Name</h1>
                    <div class="text-muted small"><code>@Model.Category.Slug</code></div>
                </div>
                <a class="btn btn-outline-secondary"
                   asp-area="Customer"
                   asp-controller="Catalog"
                   asp-action="Index">Tum kategoriler</a>
            </div>
        </div>
    </div>

    @if (Model.ChildCategories.Count > 0)
    {
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-body p-3 p-md-4">
                <h2 class="h6 text-muted mb-3">Alt kategoriler</h2>
                <div class="d-flex flex-wrap gap-2">
                @foreach (var c in Model.ChildCategories)
                {
                    <a class="btn btn-sm btn-light border"
                       asp-area="Customer"
                       asp-controller="Catalog"
                       asp-action="Category"
                       asp-route-slug="@c.Slug">
                        @c.Name
                    </a>
                }
                </div>
            </div>
        </div>
    }

    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body p-3 p-md-4">
            <form asp-area="Customer"
                  asp-controller="Catalog"
                  asp-action="Category"
                  method="get"
                  class="row g-2">
                <input type="hidden" name="slug" value="@Model.Category.Slug" />

                <div class="col-md-7">
                    <input type="text"
                           name="q"
                           value="@query"
                           class="form-control"
                           placeholder="Urun adi veya SKU ara..." />
                </div>

                <div class="col-md-3">
                    <select name="sort" class="form-select">
                        <option value="" selected="@(string.IsNullOrWhiteSpace(sort))">Ada gore (A-Z)</option>
                        <option value="price_asc" selected="@(sort == "price_asc")">Fiyat (artan)</option>
                        <option value="price_desc" selected="@(sort == "price_desc")">Fiyat (azalan)</option>
                    </select>
                </div>

                <div class="col-md-2 d-grid">
                    <button type="submit" class="btn btn-dark">Uygula</button>
                </div>
            </form>
        </div>
    </div>

    @if (Model.Products.Count == 0)
    {
        <div class="alert alert-info border-0 shadow-sm">
            Filtreye uygun aktif urun bulunamadi.
        </div>
    }
    else
    {
        <div class="d-flex align-items-center justify-content-between mb-2">
            <div class="text-muted small">@productCount urun bulundu</div>
            <a class="small text-decoration-none"
               asp-area="Customer"
               asp-controller="Cart"
               asp-action="Index">Sepete git</a>
        </div>

        <div class="row g-3">
            @foreach (var p in Model.Products)
            {
                <div class="col-12 col-md-6">
                    <div class="card border-0 shadow-sm h-100">
                        @if (!string.IsNullOrWhiteSpace(p.ImageUrl))
                        {
                            <div class="d-flex align-items-center justify-content-center" style="height:220px;background:#f8f9fa;">
                                <img src="@p.ImageUrl" alt="@p.Name" style="width:100%;height:100%;object-fit:contain;padding:8px;" />
                            </div>
                        }
                        else
                        {
                            <div class="d-flex align-items-center justify-content-center text-muted" style="height:220px;background:#f8f9fa;">Resim yok</div>
                        }
                        <div class="card-body d-flex flex-column">
                            <div class="d-flex align-items-start justify-content-between gap-2 mb-2">
                                <div class="text-muted small"><code>@p.Sku</code></div>
                                <div class="fw-semibold">@p.Price.ToString("0.00")</div>
                            </div>
                            <h3 class="h6 mb-3">
                                <a asp-area="Customer"
                                   asp-controller="Catalog"
                                   asp-action="Details"
                                   asp-route-id="@p.Id"
                                   class="text-decoration-none">
                                    @p.Name
                                </a>
                            </h3>

                            <div class="mt-auto d-flex align-items-center justify-content-between gap-2">
                                <a href="@Url.Action("Details", "Catalog", new { area = "Customer", id = p.Id })"
                                   class="btn btn-sm btn-outline-secondary">
                                    Detaya git
                                </a>

                                <form asp-area="Customer"
                                      asp-controller="Cart"
                                      asp-action="Add"
                                      method="post"
                                      class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="productId" value="@p.Id" />
                                    <input type="hidden" name="qty" value="1" />
                                    <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                    <button type="submit" class="btn btn-sm btn-dark">Sepete ekle</button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
