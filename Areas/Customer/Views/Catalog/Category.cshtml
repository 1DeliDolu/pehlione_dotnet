@model Pehlione.Models.ViewModels.Customer.CatalogCategoryDetailsVm
@{
    ViewData["Title"] = Model.Category.Name;
    var query = (string?)ViewBag.Query ?? "";
    var sort = (string?)ViewBag.Sort ?? "";
    var productCount = ViewBag.ProductCount is int n ? n : Model.Products.Count;
}

<div class="container" style="max-width: 1100px;">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <div>
            <h1 class="h3 m-0">@Model.Category.Name</h1>
            <div class="text-muted"><code>@Model.Category.Slug</code></div>
        </div>
        <a class="btn btn-outline-secondary"
           asp-area="Customer"
           asp-controller="Catalog"
           asp-action="Index">Kategoriler</a>
    </div>

    @if (Model.ChildCategories.Count > 0)
    {
        <div class="mb-3">
            <h2 class="h6 text-muted mb-2">Alt kategoriler</h2>
            <div class="list-group">
                @foreach (var c in Model.ChildCategories)
                {
                    <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"
                       asp-area="Customer"
                       asp-controller="Catalog"
                       asp-action="Category"
                       asp-route-slug="@c.Slug">
                        <span>@c.Name</span>
                        <span class="text-muted"><code>@c.Slug</code></span>
                    </a>
                }
            </div>
        </div>
    }

    <form asp-area="Customer"
          asp-controller="Catalog"
          asp-action="Category"
          method="get"
          class="row g-2 mb-3">
        <input type="hidden" name="slug" value="@Model.Category.Slug" />

        <div class="col-md-7">
            <input type="text"
                   name="q"
                   value="@query"
                   class="form-control"
                   placeholder="Urun adi veya SKU ara..." />
        </div>

        <div class="col-md-3">
            <select name="sort" class="form-select">
                <option value="" selected="@(string.IsNullOrWhiteSpace(sort))">Ada gore (A-Z)</option>
                <option value="price_asc" selected="@(sort == "price_asc")">Fiyat (artan)</option>
                <option value="price_desc" selected="@(sort == "price_desc")">Fiyat (azalan)</option>
            </select>
        </div>

        <div class="col-md-2 d-grid">
            <button type="submit" class="btn btn-outline-primary">Uygula</button>
        </div>
    </form>

    @if (Model.Products.Count == 0)
    {
        <div class="alert alert-info">
            Bu kategoride aktif urun yok.
        </div>
    }
    else
    {
        <div class="text-muted mb-2">@productCount urun bulundu.</div>
        <table class="table table-striped align-middle">
            <thead>
            <tr>
                <th>Urun</th>
                <th>SKU</th>
                <th class="text-end">Fiyat</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var p in Model.Products)
            {
                <tr>
                    <td>
                        <a asp-area="Customer"
                           asp-controller="Catalog"
                           asp-action="Details"
                           asp-route-id="@p.Id">
                            @p.Name
                        </a>
                    </td>
                    <td><code>@p.Sku</code></td>
                    <td class="text-end">@p.Price.ToString("0.00")</td>
                </tr>
            }
            </tbody>
        </table>
    }
</div>
