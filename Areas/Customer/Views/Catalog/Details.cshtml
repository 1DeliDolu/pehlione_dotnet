@model Pehlione.Models.ViewModels.Customer.CatalogProductDetailsVm
@{
    ViewData["Title"] = Model.Name;
}

<div class="container" style="max-width: 900px;">
    <div class="mb-3">
        <a class="btn btn-outline-secondary btn-sm"
           asp-area="Customer"
           asp-controller="Catalog"
           asp-action="Category"
           asp-route-slug="@Model.CategorySlug">
            <- @Model.CategoryName
        </a>
    </div>

    <h1 class="h3 mb-1">@Model.Name</h1>
    <div class="text-muted mb-3">
        SKU: <code>@Model.Sku</code>
    </div>

    <div class="card">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div class="text-muted">Fiyat</div>
                    <div class="h4 m-0">@Model.Price.ToString("0.00")</div>
                </div>

                <div class="text-muted">
                    (Sonraki adim: Sepete ekle)
                </div>
            </div>
        </div>
    </div>
</div>
