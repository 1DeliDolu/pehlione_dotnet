@model Pehlione.Models.ViewModels.Customer.CatalogProductDetailsVm
@{
    ViewData["Title"] = Model.Name;
}

<div class="container" style="max-width: 900px;">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <a class="btn btn-outline-secondary btn-sm"
           asp-area="Customer"
           asp-controller="Catalog"
           asp-action="Category"
           asp-route-slug="@Model.CategorySlug">
            <- @Model.CategoryName
        </a>

        <a class="btn btn-outline-primary btn-sm"
           asp-area="Customer"
           asp-controller="Cart"
           asp-action="Index">
            Sepet
        </a>
    </div>

    <h1 class="h3 mb-1">@Model.Name</h1>
    <div class="text-muted mb-3">
        SKU: <code>@Model.Sku</code>
    </div>

    <div class="card">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div class="text-muted">Fiyat</div>
                    <div class="h4 m-0">@Model.Price.ToString("0.00")</div>
                </div>

                <form asp-area="Customer"
                      asp-controller="Cart"
                      asp-action="Add"
                      method="post"
                      class="d-flex gap-2 align-items-center">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="productId" value="@Model.Id" />
                    <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />

                    <input type="number" name="qty" value="1" min="1" max="99" class="form-control" style="width: 110px;" />
                    <button type="submit" class="btn btn-primary">Sepete ekle</button>
                </form>
            </div>
        </div>
    </div>
</div>
