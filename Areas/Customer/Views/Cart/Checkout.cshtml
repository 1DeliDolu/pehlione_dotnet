@model Pehlione.Models.ViewModels.Customer.CheckoutVm
@{
    ViewData["Title"] = "Checkout";
    var step = Model.Step;
}

<div class="container py-3" style="max-width: 980px;">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <h1 class="h3 m-0">Checkout</h1>
        <a class="btn btn-outline-secondary" asp-area="Customer" asp-controller="Cart" asp-action="Index">Sepete don</a>
    </div>

    <div class="mb-3">
        <div class="progress" role="progressbar" aria-label="Checkout adimlari">
            <div class="progress-bar" style="width: @(step * 25)%"></div>
        </div>
        <div class="small text-muted mt-2">1. Kullanici Bilgileri - 2. Adres - 3. Odeme - 4. Onay</div>
    </div>

    @if (step == 1)
    {
        <form asp-area="Customer" asp-controller="Cart" asp-action="CheckoutUser" method="post" class="card border-0 shadow-sm">
            @Html.AntiForgeryToken()
            <div class="card-body p-3 p-md-4">
                <h2 class="h5 mb-3">Kullanici Bilgileri</h2>
                <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>
                <div class="row g-3">
                    <div class="col-12 col-md-6">
                        <label asp-for="User.FullName" class="form-label"></label>
                        <input asp-for="User.FullName" class="form-control" />
                        <span asp-validation-for="User.FullName" class="text-danger small"></span>
                    </div>
                    <div class="col-12 col-md-6">
                        <label asp-for="User.Email" class="form-label"></label>
                        <input asp-for="User.Email" class="form-control" />
                        <span asp-validation-for="User.Email" class="text-danger small"></span>
                    </div>
                    <div class="col-12 col-md-6">
                        <label asp-for="User.Phone" class="form-label"></label>
                        <input asp-for="User.Phone" class="form-control" />
                        <span asp-validation-for="User.Phone" class="text-danger small"></span>
                    </div>
                </div>
                <div class="mt-3 text-end">
                    <button type="submit" class="btn btn-dark">Devam et</button>
                </div>
            </div>
        </form>
    }
    else if (step == 2)
    {
        <form asp-area="Customer" asp-controller="Cart" asp-action="CheckoutAddress" method="post" class="card border-0 shadow-sm">
            @Html.AntiForgeryToken()
            <div class="card-body p-3 p-md-4">
                <h2 class="h5 mb-3">Adres</h2>
                <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>
                @if (Model.SavedAddresses.Count > 0)
                {
                    <div class="mb-3">
                        <label asp-for="Address.SelectedAddressId" class="form-label">Kayitli Adresler</label>
                        <select asp-for="Address.SelectedAddressId" class="form-select">
                            <option value="">Yeni adres gir</option>
                            @foreach (var a in Model.SavedAddresses)
                            {
                                <option value="@a.Id">@a.Label @(a.IsDefault ? "[Varsayilan]" : "")</option>
                            }
                        </select>
                    </div>
                }
                <div class="row g-3">
                    <div class="col-12">
                        <label asp-for="Address.Title" class="form-label"></label>
                        <input asp-for="Address.Title" class="form-control" />
                        <span asp-validation-for="Address.Title" class="text-danger small"></span>
                    </div>
                    <div class="col-12">
                        <label asp-for="Address.Street" class="form-label"></label>
                        <input asp-for="Address.Street" class="form-control" />
                        <span asp-validation-for="Address.Street" class="text-danger small"></span>
                    </div>
                    <div class="col-12 col-md-4">
                        <label asp-for="Address.HouseNumber" class="form-label"></label>
                        <input asp-for="Address.HouseNumber" class="form-control" />
                        <span asp-validation-for="Address.HouseNumber" class="text-danger small"></span>
                    </div>
                    <div class="col-12">
                        <label asp-for="Address.Line2" class="form-label"></label>
                        <input asp-for="Address.Line2" class="form-control" />
                    </div>
                    <div class="col-12 col-md-4">
                        <label asp-for="Address.City" class="form-label"></label>
                        <input asp-for="Address.City" class="form-control" />
                        <span asp-validation-for="Address.City" class="text-danger small"></span>
                    </div>
                    <div class="col-12 col-md-4">
                        <label asp-for="Address.PostalCode" class="form-label"></label>
                        <input asp-for="Address.PostalCode" class="form-control" />
                        <span asp-validation-for="Address.PostalCode" class="text-danger small"></span>
                    </div>
                    <div class="col-12 col-md-4">
                        <label asp-for="Address.State" class="form-label"></label>
                        <input asp-for="Address.State" class="form-control" />
                    </div>
                    <div class="col-12 col-md-4">
                        <label asp-for="Address.CountryCode" class="form-label"></label>
                        <input asp-for="Address.CountryCode" class="form-control text-uppercase" maxlength="2" />
                        <span asp-validation-for="Address.CountryCode" class="text-danger small"></span>
                    </div>
                    <div class="col-12 col-md-8">
                        <label asp-for="Address.PhoneNumber" class="form-label"></label>
                        <input asp-for="Address.PhoneNumber" class="form-control" />
                    </div>
                </div>
                <div class="mt-3 d-flex justify-content-between">
                    <a class="btn btn-outline-secondary" asp-area="Customer" asp-controller="Cart" asp-action="Checkout" asp-route-step="1">Geri</a>
                    <button type="submit" class="btn btn-dark">Devam et</button>
                </div>
            </div>
        </form>
    }
    else if (step == 3)
    {
        <form asp-area="Customer" asp-controller="Cart" asp-action="CheckoutPayment" method="post" class="card border-0 shadow-sm">
            @Html.AntiForgeryToken()
            <div class="card-body p-3 p-md-4">
                <h2 class="h5 mb-3">Odeme</h2>
                <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>
                @if (Model.SavedPaymentMethods.Count > 0)
                {
                    <div class="mb-3">
                        <label asp-for="Payment.SelectedPaymentMethodId" class="form-label">Kayitli Odeme Yontemleri</label>
                        <select asp-for="Payment.SelectedPaymentMethodId" class="form-select">
                            <option value="">Yeni odeme yontemi gir</option>
                            @foreach (var pm in Model.SavedPaymentMethods)
                            {
                                <option value="@pm.Id">@pm.Label (@pm.Type) @(pm.IsDefault ? "[Varsayilan]" : "")</option>
                            }
                        </select>
                    </div>
                }
                <div class="mb-3">
                    <label asp-for="Payment.Method" class="form-label"></label>
                    <select asp-for="Payment.Method" class="form-select">
                        <option value="Klarna">Klarna</option>
                        <option value="PayPal">PayPal</option>
                        <option value="Visa">Visa</option>
                        <option value="Mastercard">Mastercard</option>
                    </select>
                </div>
                <div class="row g-3">
                    <div class="col-12 col-md-6">
                        <label asp-for="Payment.CardHolder" class="form-label"></label>
                        <input asp-for="Payment.CardHolder" class="form-control" />
                    </div>
                    <div class="col-12 col-md-6">
                        <label asp-for="Payment.CardLast4" class="form-label"></label>
                        <input asp-for="Payment.CardLast4" class="form-control" maxlength="4" />
                        <span asp-validation-for="Payment.CardLast4" class="text-danger small"></span>
                    </div>
                </div>
                <div class="mt-3 d-flex justify-content-between">
                    <a class="btn btn-outline-secondary" asp-area="Customer" asp-controller="Cart" asp-action="Checkout" asp-route-step="2">Geri</a>
                    <button type="submit" class="btn btn-dark">Devam et</button>
                </div>
            </div>
        </form>
    }
    else
    {
        <div class="row g-3">
            <div class="col-12 col-lg-7">
                <div class="card border-0 shadow-sm">
                    <div class="card-body p-3 p-md-4">
                        <h2 class="h5 mb-3">Onay</h2>
                        <div class="mb-2"><strong>Kullanici:</strong> @Model.User.FullName</div>
                        <div class="mb-2"><strong>E-posta:</strong> @Model.User.Email</div>
                        <div class="mb-2"><strong>Telefon:</strong> @Model.User.Phone</div>
                        <hr />
                        <div class="mb-2"><strong>Adres Basligi:</strong> @Model.Address.Title</div>
                        <div class="mb-2"><strong>Adres:</strong> @Model.Address.Street @Model.Address.HouseNumber @Model.Address.Line2</div>
                        <div class="mb-2"><strong>Sehir:</strong> @Model.Address.City</div>
                        <div class="mb-2"><strong>Posta Kodu:</strong> @Model.Address.PostalCode</div>
                        <div class="mb-2"><strong>Eyalet:</strong> @Model.Address.State</div>
                        <div class="mb-2"><strong>Ulke Kodu:</strong> @Model.Address.CountryCode</div>
                        <div class="mb-2"><strong>Telefon:</strong> @Model.Address.PhoneNumber</div>
                        <hr />
                        <div class="mb-2"><strong>Odeme:</strong> @Model.Payment.Method</div>
                        @if (!string.IsNullOrWhiteSpace(Model.Payment.CardHolder))
                        {
                            <div class="mb-2"><strong>Gorunen Ad:</strong> @Model.Payment.CardHolder</div>
                        }
                        @if (!string.IsNullOrWhiteSpace(Model.Payment.CardLast4))
                        {
                            <div class="mb-2"><strong>Kart Son 4:</strong> **** @Model.Payment.CardLast4</div>
                        }
                    </div>
                </div>
            </div>
            <div class="col-12 col-lg-5">
                <div class="card border-0 shadow-sm">
                    <div class="card-body p-3 p-md-4">
                        <h2 class="h5 mb-3">Siparis Ozeti</h2>
                        @foreach (var line in Model.Cart.Lines)
                        {
                            <div class="d-flex justify-content-between small mb-2">
                                <span>@line.Name x @line.Quantity</span>
                                <strong>@line.Subtotal.ToString("0.00")</strong>
                            </div>
                        }
                        <hr />
                        <div class="d-flex justify-content-between">
                            <span>Toplam</span>
                            <strong>@Model.Cart.Total.ToString("0.00")</strong>
                        </div>
                        <div class="mt-3 d-flex justify-content-between">
                            <a class="btn btn-outline-secondary" asp-area="Customer" asp-controller="Cart" asp-action="Checkout" asp-route-step="3">Geri</a>
                            <form asp-area="Customer" asp-controller="Cart" asp-action="PlaceOrder" method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-success">Siparisi Tamamla</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
