@model Pehlione.Models.ViewModels.Customer.CartVm
@{
    ViewData["Title"] = "Sepet";
}

<div class="container" style="max-width: 1100px;">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <h1 class="h3 m-0">Sepet</h1>
        <a class="btn btn-outline-secondary" asp-area="Customer" asp-controller="Catalog" asp-action="Index">Kataloga don</a>
    </div>

    @if (Model.Lines.Count == 0)
    {
        <div class="alert alert-info">Sepet bos.</div>
    }
    else
    {
        <table class="table table-striped align-middle">
            <thead>
            <tr>
                <th>Urun</th>
                <th>SKU</th>
                <th class="text-end">Birim Fiyat</th>
                <th class="text-end">Adet</th>
                <th class="text-end">Ara Toplam</th>
                <th class="text-end">Islem</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var l in Model.Lines)
            {
                <tr>
                    <td>
                        <a asp-area="Customer"
                           asp-controller="Catalog"
                           asp-action="Details"
                           asp-route-id="@l.ProductId">@l.Name</a>
                    </td>
                    <td><code>@l.Sku</code></td>
                    <td class="text-end">@l.UnitPrice.ToString("0.00")</td>

                    <td class="text-end" style="width: 220px;">
                        <form asp-area="Customer"
                              asp-controller="Cart"
                              asp-action="Update"
                              method="post"
                              class="d-flex justify-content-end gap-2">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="productId" value="@l.ProductId" />
                            <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />

                            <input type="number"
                                   name="qty"
                                   value="@l.Quantity"
                                   min="1"
                                   max="99"
                                   class="form-control"
                                   style="width: 110px;" />

                            <button type="submit" class="btn btn-outline-primary">Guncelle</button>
                        </form>
                    </td>

                    <td class="text-end">@l.Subtotal.ToString("0.00")</td>

                    <td class="text-end" style="width: 140px;">
                        <form asp-area="Customer"
                              asp-controller="Cart"
                              asp-action="Remove"
                              method="post"
                              class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="productId" value="@l.ProductId" />
                            <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                            <button type="submit" class="btn btn-outline-danger">Cikar</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
            <tfoot>
            <tr>
                <th colspan="4" class="text-end">Toplam</th>
                <th class="text-end">@Model.Total.ToString("0.00")</th>
                <th></th>
            </tr>
            </tfoot>
        </table>
    }
</div>
