@{
    var searchId = "adminFormSearch_" + Guid.NewGuid().ToString("N");
}

<div class="card border-0 shadow-sm rounded-4 mb-3">
    <div class="card-body p-3">
        <label class="form-label fw-semibold mb-2" for="@searchId">Formda Ara</label>
        <input id="@searchId" type="search" class="form-control" placeholder="Alan/etiket ara..." />
    </div>
</div>

<script>
    (function () {
        const input = document.getElementById('@searchId');
        if (!input) return;

        const root = input.closest('.container-fluid') || document;
        const target = root.querySelector('.js-form-search-target');
        if (!target) return;

        const nodeList = target.querySelectorAll('.mb-3, .form-check, .row.g-3 > div, .row.g-2 > div');
        const fields = Array.from(new Set(Array.from(nodeList)));

        input.addEventListener('input', function () {
            const q = (input.value || '').toLowerCase().trim();
            for (const field of fields) {
                if (!q) {
                    field.style.display = '';
                    continue;
                }

                const text = (field.textContent || '').toLowerCase();
                field.style.display = text.includes(q) ? '' : 'none';
            }
        });
    })();
</script>
