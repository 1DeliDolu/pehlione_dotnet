@model Pehlione.Models.ViewModels.Admin.AdminStockFormVm
@{
    ViewData["Title"] = "Departman Operasyonu: Stok Artir / Azalt";
}

<div class="container-fluid py-4">
    <partial name="_AdminNav" />
    <partial name="_AdminFormSearch" />

    @if (TempData["AdminSuccess"] is string ok && !string.IsNullOrWhiteSpace(ok))
    {
        <div class="alert alert-success shadow-sm">@ok</div>
    }
    @if (TempData["AdminError"] is string err && !string.IsNullOrWhiteSpace(err))
    {
        <div class="alert alert-warning shadow-sm">@err</div>
    }

    <form asp-area="Admin" asp-controller="Home" asp-action="QuickStockOperation" method="post" class="card border-0 shadow-sm rounded-4 js-form-search-target">
        @Html.AntiForgeryToken()
        <input type="hidden" name="returnTo" value="StockForm" />

        <div class="card-header bg-white border-0 pt-4 px-4">
            <h1 class="h5 mb-1">Departman Operasyonu: Stok Artir / Azalt</h1>
            <p class="text-muted small mb-0">Admin, Purchasing ve Warehouse islemlerini bu formdan yapar.</p>
        </div>

        <div class="card-body px-4 pb-4">
            <div class="row g-3">
                <div class="col-12">
                    <label class="form-label fw-semibold">Urun</label>
                    <select name="ProductId" class="form-select form-select-lg">
                        @foreach (var p in Model.ProductOptions)
                        {
                            <option value="@p.Value">@p.Label</option>
                        }
                    </select>
                </div>
                <div class="col-12 col-lg-6">
                    <label class="form-label fw-semibold">Adet</label>
                    <input name="Quantity" type="number" min="1" value="1" class="form-control form-control-lg" />
                </div>
                <div class="col-12 col-lg-6">
                    <label class="form-label fw-semibold">Islem</label>
                    <select name="OperationType" class="form-select form-select-lg">
                        <option value="Increase">Stok Artir</option>
                        <option value="Decrease">Stok Azalt</option>
                    </select>
                </div>
            </div>
            <div class="d-flex justify-content-end mt-4">
                <button type="submit" class="btn btn-primary btn-lg px-4">Stok Islemi Yap</button>
            </div>
        </div>
    </form>
</div>
