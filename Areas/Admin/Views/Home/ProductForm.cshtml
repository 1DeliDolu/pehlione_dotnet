@model Pehlione.Models.ViewModels.Admin.ProductCreateVm
@{
    ViewData["Title"] = "Urun Ekleme Formu";
}

<div class="container-fluid py-4">
    <partial name="_AdminNav" />
    <partial name="_AdminFormSearch" />

    @if (TempData["AdminSuccess"] is string ok && !string.IsNullOrWhiteSpace(ok))
    {
        <div class="alert alert-success shadow-sm">@ok</div>
    }
    @if (TempData["AdminError"] is string err && !string.IsNullOrWhiteSpace(err))
    {
        <div class="alert alert-warning shadow-sm">@err</div>
    }

    <form asp-area="Admin" asp-controller="Home" asp-action="QuickCreateProduct" method="post" class="card border-0 shadow-sm rounded-4 js-form-search-target">
        @Html.AntiForgeryToken()
        <input type="hidden" name="returnTo" value="ProductForm" />

        <div class="card-header bg-white border-0 pt-4 px-4">
            <h1 class="h5 mb-1">Urun Ekleme Formu</h1>
            <p class="text-muted small mb-0">Bootstrap ile modern urun ekleme</p>
        </div>

        <div class="card-body px-4 pb-4">
            <div class="row g-3">
                <div class="col-12">
                    <label class="form-label fw-semibold">Kategori</label>
                    <select name="CategoryId" class="form-select form-select-lg" required>
                        @foreach (var c in Model.CategoryOptions)
                        {
                            <option value="@c.Id">@c.Name</option>
                        }
                    </select>
                </div>
                <div class="col-12">
                    <label class="form-label fw-semibold">Urun Adi</label>
                    <input name="Name" type="text" class="form-control form-control-lg" required />
                </div>
                <div class="col-12">
                    <label class="form-label fw-semibold">SKU</label>
                    <input name="Sku" type="text" class="form-control form-control-lg" required />
                </div>
                <div class="col-12 col-lg-6">
                    <label class="form-label fw-semibold">Fiyat</label>
                    <input name="Price" type="number" min="0.01" step="0.01" value="1" class="form-control form-control-lg" required />
                </div>
                <div class="col-12 col-lg-6 d-flex align-items-end">
                    <div class="form-check form-switch mb-2">
                        <input class="form-check-input" type="checkbox" id="IsActive" name="IsActive" checked />
                        <label class="form-check-label" for="IsActive">Aktif</label>
                    </div>
                </div>
            </div>
            <div class="d-flex justify-content-end mt-4">
                <button type="submit" class="btn btn-primary btn-lg px-4">Urun Ekle</button>
            </div>
        </div>
    </form>
</div>
