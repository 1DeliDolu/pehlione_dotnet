@model IReadOnlyList<Pehlione.Models.ViewModels.Admin.OrderListItemVm>
@{
    ViewData["Title"] = "Siparisler";
    var query = (string?)ViewBag.Query ?? "";
    var selectedStatus = (string?)ViewBag.Status ?? "";
    var statuses = ViewBag.Statuses as string[] ?? Array.Empty<string>();
    var shippingCarriers = ViewBag.ShippingCarriers as string[] ?? Array.Empty<string>();
}

<div class="container-fluid py-4">
    <partial name="_AdminNav" />

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <h1 class="h3 m-0">Siparisler</h1>
            </div>

            @if (TempData["AdminSuccess"] is string success && !string.IsNullOrWhiteSpace(success))
            {
                <div class="alert alert-success py-2">@success</div>
            }
            @if (TempData["AdminError"] is string error && !string.IsNullOrWhiteSpace(error))
            {
                <div class="alert alert-danger py-2">@error</div>
            }

            <form method="get" asp-area="Admin" asp-controller="Orders" asp-action="Index" class="row g-2 mb-3">
                <div class="col-12 col-md-5">
                    <input type="text" name="q" value="@query" class="form-control" placeholder="Siparis no veya e-posta ara..." />
                </div>
                <div class="col-12 col-md-3">
                    <select name="status" class="form-select">
                        <option value="">Tum durumlar</option>
                        @foreach (var s in statuses)
                        {
                            <option value="@s" selected="@(selectedStatus == s)">@s</option>
                        }
                    </select>
                </div>
                <div class="col-12 col-md-2 d-grid">
                    <button type="submit" class="btn btn-outline-primary">Filtrele</button>
                </div>
            </form>

            @if (Model.Count == 0)
            {
                <div class="alert alert-info mb-0">Siparis bulunamadi.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Tarih</th>
                            <th>Musteri</th>
                            <th>Durum</th>
                            <th>Durum Guncelle</th>
                            <th>Kargo</th>
                            <th>Kalem</th>
                            <th class="text-end">Tutar</th>
                        </tr>
                        </thead>
                        <tbody>
                        @foreach (var o in Model)
                        {
                            var nextOptions = o.NextStatusOptions ?? Array.Empty<string>();
                            var canEdit = nextOptions.Count > 0;
                            <tr>
                                <td>#@o.Id</td>
                                <td>@o.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                                <td>@o.CustomerEmail</td>
                                <td><span class="badge text-bg-light">@o.Status</span></td>
                                <td>
                                    <form method="post" asp-area="Admin" asp-controller="Orders" asp-action="UpdateStatus" class="d-flex flex-column gap-2">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@o.Id" />
                                        <input type="hidden" name="q" value="@query" />
                                        <input type="hidden" name="currentStatus" value="@selectedStatus" />
                                        <select name="status" class="form-select form-select-sm" disabled="@(!canEdit)">
                                            @foreach (var option in nextOptions)
                                            {
                                                <option value="@option">@option</option>
                                            }
                                        </select>
                                        <div class="row g-2">
                                            <div class="col-12 col-lg-6">
                                                <select name="shippingCarrier" class="form-select form-select-sm">
                                                    <option value="">Kargo firmasi (Shipped icin)</option>
                                                    @foreach (var c in shippingCarriers)
                                                    {
                                                        <option value="@c" selected="@(string.Equals(o.ShippingCarrier, c, StringComparison.OrdinalIgnoreCase))">@c</option>
                                                    }
                                                </select>
                                            </div>
                                            <div class="col-12 col-lg-6">
                                                <input type="text" name="trackingCode" value="@o.TrackingCode" class="form-control form-control-sm" placeholder="Takip kodu (opsiyonel)" />
                                            </div>
                                        </div>
                                        <button type="submit" class="btn btn-sm btn-outline-primary align-self-start" disabled="@(!canEdit)">Kaydet</button>
                                    </form>
                                </td>
                                <td class="small text-muted">
                                    @(string.IsNullOrWhiteSpace(o.ShippingCarrier) ? "-" : o.ShippingCarrier)
                                    @if (!string.IsNullOrWhiteSpace(o.TrackingCode))
                                    {
                                        <span class="d-block">@o.TrackingCode</span>
                                    }
                                </td>
                                <td>@o.ItemCount</td>
                                <td class="text-end fw-semibold">@o.TotalAmount.ToString("0.00") @o.Currency</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
