@model IReadOnlyList<Pehlione.Models.ViewModels.Admin.ProductListItemVm>
@using Pehlione.Models.ViewModels.Admin
@{
    ViewData["Title"] = "Urunler";
    var query = (string?)ViewBag.Query ?? "";
    int? selectedCategoryId = ViewBag.CategoryId is int cid ? cid : (int?)null;
    bool? selectedIsActive = ViewBag.IsActive is bool active ? active : (bool?)null;
    var categoryOptions = ViewBag.CategoryOptions as IReadOnlyList<ProductCategoryOptionVm> ?? Array.Empty<ProductCategoryOptionVm>();
}

<div class="container-fluid py-4">
    <partial name="_AdminNav" />
    <partial name="_AdminFormSearch" />
    <div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-4">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <h1 class="h3 m-0">Urunler</h1>
        <a class="btn btn-primary" asp-area="Admin" asp-controller="Products" asp-action="Create">Yeni urun</a>
    </div>

    <form method="get" asp-area="Admin" asp-controller="Products" asp-action="Index" class="row g-2 mb-3 js-form-search-target">
        <div class="col-md-5">
            <input type="text" name="q" value="@query" class="form-control" placeholder="Ad veya SKU ara..." />
        </div>
        <div class="col-md-4">
            <select name="categoryId" class="form-select">
                <option value="">Tum kategoriler</option>
                @foreach (var c in categoryOptions)
                {
                    <option value="@c.Id" selected="@(selectedCategoryId == c.Id)">@c.Name</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <select name="isActive" class="form-select">
                <option value="">Tum durumlar</option>
                <option value="true" selected="@(selectedIsActive == true)">Aktif</option>
                <option value="false" selected="@(selectedIsActive == false)">Pasif</option>
            </select>
        </div>
        <div class="col-md-1 d-grid">
            <button type="submit" class="btn btn-outline-primary">Filtrele</button>
        </div>
    </form>

    @if (Model.Count == 0)
    {
        <div class="alert alert-info">Filtreye uygun urun bulunamadi.</div>
    }
    else
    {
        <table class="table table-striped align-middle">
            <thead>
            <tr>
                <th>Resim</th>
                <th>Ad</th>
                <th>SKU</th>
                <th>Kategori</th>
                <th class="text-end">Fiyat</th>
                <th>Durum</th>
                <th class="text-end">Islem</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var p in Model)
            {
                var firstImage = p.ImageUrls.FirstOrDefault();
                <tr>
                    <td style="width: 92px;">
                        @if (!string.IsNullOrWhiteSpace(firstImage))
                        {
                            <img src="@firstImage" alt="@p.Name" style="width:64px;height:64px;object-fit:cover;border-radius:8px;" />
                            @if (p.ImageUrls.Count > 1)
                            {
                                <div class="small text-muted mt-1">+@(p.ImageUrls.Count - 1)</div>
                            }
                        }
                        else
                        {
                            <span class="text-muted small">Resim yok</span>
                        }
                    </td>
                    <td>@p.Name</td>
                    <td><code>@p.Sku</code></td>
                    <td>@p.CategoryName</td>
                    <td class="text-end">@p.Price.ToString("0.00")</td>
                    <td>
                        @if (p.IsActive)
                        {
                            <span class="badge bg-success">Aktif</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Pasif</span>
                        }
                    </td>
                    <td class="text-end">
                        <div class="d-inline-flex gap-2">
                            <a class="btn btn-sm btn-dark"
                               asp-area="Admin"
                               asp-controller="Products"
                               asp-action="Product"
                               asp-route-id="@p.Id">Goruntule</a>

                            <a class="btn btn-sm btn-outline-primary"
                               asp-area="Admin"
                               asp-controller="Products"
                               asp-action="Edit"
                               asp-route-id="@p.Id">Duzenle</a>

                            <a class="btn btn-sm btn-outline-danger"
                               asp-area="Admin"
                               asp-controller="Products"
                               asp-action="Delete"
                               asp-route-id="@p.Id">Sil</a>
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    }

    <p class="text-muted mb-0">
        Not: SKU benzersiz olmali; duzenlerken de cakisma kontrolu yapilir.
    </p>
    </div>
    </div>
</div>
