@model Pehlione.Models.ViewModels.Admin.ProductDetailsVm
@{
    ViewData["Title"] = "Urun Goruntule";
    var firstImage = Model.ImageUrls.FirstOrDefault() ?? "https://placehold.co/1200x900?text=No+Image";
}

<div class="container-fluid py-4 product-view-page">
    <partial name="_AdminNav" />
    <partial name="_AdminFormSearch" />

    <div class="d-flex align-items-center justify-content-between mb-3">
        <h1 class="h3 m-0">Urun goruntule</h1>
        <div class="d-flex gap-2">
            <a class="btn btn-outline-secondary" asp-area="Admin" asp-controller="Products" asp-action="Index">Listeye don</a>
            <a class="btn btn-primary" asp-area="Admin" asp-controller="Products" asp-action="Edit" asp-route-id="@Model.Id">Duzenle</a>
        </div>
    </div>

    <div class="product-view-shell rounded-4 p-3 p-lg-4">
        <div class="row g-4 align-items-start">
            <div class="col-lg-7">
                <div class="gallery-main-wrapper">
                    <img id="mainImage" class="gallery-main-image" src="@firstImage" alt="@Model.Name" />
                </div>

                @if (Model.ImageUrls.Count > 0)
                {
                    <div class="gallery-thumbs mt-3">
                        @for (var i = 0; i < Model.ImageUrls.Count; i++)
                        {
                            var image = Model.ImageUrls[i];
                            <button type="button" class="thumb-btn" data-index="@i" data-image="@image">
                                <img src="@image" alt="@Model.Name - @(i + 1)" />
                            </button>
                        }
                    </div>
                }
            </div>

            <div class="col-lg-5">
                <div class="product-info-card rounded-4 p-4">
                    <p class="text-uppercase small text-muted mb-2">@Model.CategoryName</p>
                    <h2 class="h3 mb-3">@Model.Name</h2>

                    <div class="d-flex align-items-center gap-2 mb-3">
                        @if (Model.IsActive)
                        {
                            <span class="badge bg-success">Aktif</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Pasif</span>
                        }
                        <span class="text-muted small">Toplam @Model.ImageUrls.Count resim</span>
                    </div>

                    <dl class="row mb-0">
                        <dt class="col-4 text-muted">SKU</dt>
                        <dd class="col-8"><code>@Model.Sku</code></dd>

                        <dt class="col-4 text-muted">Fiyat</dt>
                        <dd class="col-8 fw-semibold">@Model.Price.ToString("0.00")</dd>

                        <dt class="col-4 text-muted">ID</dt>
                        <dd class="col-8">@Model.Id</dd>
                    </dl>
                </div>
            </div>
        </div>
    </div>
</div>

@if (Model.ImageUrls.Count > 0)
{
    <div id="imageLightbox" class="image-lightbox" aria-hidden="true">
        <button type="button" class="lightbox-close" data-close="true" aria-label="Kapat">x</button>
        <button type="button" class="lightbox-nav prev" data-nav="-1" aria-label="Onceki resim">&#10094;</button>
        <img id="lightboxImage" class="lightbox-image" src="@firstImage" alt="@Model.Name" />
        <button type="button" class="lightbox-nav next" data-nav="1" aria-label="Sonraki resim">&#10095;</button>
    </div>
}

<style>
    .product-view-page {
        background: radial-gradient(circle at top right, #f8f9ff 0%, #f3f6f9 42%, #eef2f5 100%);
    }

    .product-view-shell {
        background: rgba(255, 255, 255, 0.9);
        border: 1px solid #e8edf2;
        box-shadow: 0 12px 34px rgba(20, 34, 56, 0.08);
    }

    .gallery-main-wrapper {
        background: #fff;
        border: 1px solid #e9edf2;
        border-radius: 16px;
        overflow: hidden;
    }

    .gallery-main-image {
        width: 100%;
        aspect-ratio: 4 / 3;
        object-fit: cover;
        display: block;
        cursor: zoom-in;
    }

    .gallery-thumbs {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(88px, 1fr));
        gap: 10px;
    }

    .thumb-btn {
        border: 2px solid transparent;
        border-radius: 10px;
        background: #fff;
        padding: 0;
        overflow: hidden;
        cursor: pointer;
        transition: transform .15s ease, border-color .15s ease;
    }

    .thumb-btn:hover {
        transform: translateY(-2px);
        border-color: #c9d9ff;
    }

    .thumb-btn.active {
        border-color: #0d6efd;
    }

    .thumb-btn img {
        width: 100%;
        aspect-ratio: 1 / 1;
        object-fit: cover;
        display: block;
    }

    .product-info-card {
        background: linear-gradient(170deg, #ffffff 0%, #f8fbff 100%);
        border: 1px solid #e8edf2;
    }

    .image-lightbox {
        position: fixed;
        inset: 0;
        display: none;
        align-items: center;
        justify-content: center;
        background: rgba(9, 13, 24, 0.86);
        z-index: 2000;
        padding: 24px;
    }

    .image-lightbox.open {
        display: flex;
    }

    .lightbox-image {
        max-width: min(92vw, 1400px);
        max-height: 88vh;
        width: auto;
        height: auto;
        border-radius: 12px;
        box-shadow: 0 18px 54px rgba(0, 0, 0, 0.45);
        object-fit: contain;
    }

    .lightbox-close,
    .lightbox-nav {
        position: absolute;
        border: 0;
        border-radius: 10px;
        background: rgba(255, 255, 255, 0.16);
        color: #fff;
        cursor: pointer;
        backdrop-filter: blur(4px);
    }

    .lightbox-close {
        top: 18px;
        right: 18px;
        font-size: 24px;
        width: 44px;
        height: 44px;
        line-height: 1;
    }

    .lightbox-nav {
        top: 50%;
        transform: translateY(-50%);
        font-size: 28px;
        width: 52px;
        height: 64px;
    }

    .lightbox-nav.prev {
        left: 18px;
    }

    .lightbox-nav.next {
        right: 18px;
    }
</style>

@section Scripts {
    <script>
        (function () {
            const mainImage = document.getElementById('mainImage');
            const thumbs = Array.from(document.querySelectorAll('.thumb-btn'));
            const lightbox = document.getElementById('imageLightbox');
            const lightboxImage = document.getElementById('lightboxImage');
            const allImages = thumbs.map(x => x.getAttribute('data-image')).filter(Boolean);
            let activeIndex = 0;
            if (!mainImage || allImages.length === 0) return;

            function setActiveByIndex(index) {
                activeIndex = index;
                const next = allImages[index];
                if (!next) return;
                mainImage.src = next;
                thumbs.forEach(x => x.classList.remove('active'));
                const active = thumbs.find(x => Number(x.getAttribute('data-index')) === index);
                if (active) active.classList.add('active');
            }

            thumbs.forEach((btn, index) => {
                if (index === 0) setActiveByIndex(0);
                btn.addEventListener('click', () => {
                    setActiveByIndex(index);
                });
            });

            function renderLightbox() {
                if (!lightboxImage) return;
                const next = allImages[activeIndex];
                if (!next) return;
                lightboxImage.src = next;
            }

            function openLightbox() {
                if (!lightbox) return;
                renderLightbox();
                lightbox.classList.add('open');
                lightbox.setAttribute('aria-hidden', 'false');
            }

            function closeLightbox() {
                if (!lightbox) return;
                lightbox.classList.remove('open');
                lightbox.setAttribute('aria-hidden', 'true');
            }

            function navigate(step) {
                if (allImages.length === 0) return;
                activeIndex = (activeIndex + step + allImages.length) % allImages.length;
                setActiveByIndex(activeIndex);
                renderLightbox();
            }

            mainImage.addEventListener('click', openLightbox);
            thumbs.forEach((btn, index) => {
                btn.addEventListener('dblclick', () => {
                    setActiveByIndex(index);
                    openLightbox();
                });
            });

            if (lightbox) {
                lightbox.addEventListener('click', (event) => {
                    const target = event.target;
                    if (!(target instanceof Element)) return;

                    if (target.hasAttribute('data-close') || target === lightbox) {
                        closeLightbox();
                        return;
                    }

                    const nav = target.getAttribute('data-nav');
                    if (!nav) return;
                    navigate(Number(nav));
                });
            }

            document.addEventListener('keydown', (event) => {
                if (!lightbox || !lightbox.classList.contains('open')) return;
                if (event.key === 'Escape') closeLightbox();
                if (event.key === 'ArrowLeft') navigate(-1);
                if (event.key === 'ArrowRight') navigate(1);
            });
        })();
    </script>
}
