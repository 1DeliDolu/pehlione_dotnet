@model Pehlione.Models.ViewModels.Admin.CategoryDeleteVm
@{
    ViewData["Title"] = "Kategori Sil";
}

<div class="container-fluid py-4">
    <partial name="_AdminNav" />
    <div class="card border-0 shadow-sm rounded-4" style="max-width: 860px;">
    <div class="card-body p-4">
    <h1 class="h3 mb-3">Kategori sil</h1>

    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="card">
        <div class="card-body">
            <p class="mb-1"><strong>Ad:</strong> @Model.Name</p>
            <p class="mb-3"><strong>Slug:</strong> <code>@Model.Slug</code></p>

            @if (Model.HasProducts)
            {
                <div class="alert alert-warning mb-3">
                    Bu kategoriye bagli urunler var. Silme islemi engellendi.
                </div>

                <a class="btn btn-outline-primary"
                   asp-area="Admin"
                   asp-controller="Categories"
                   asp-action="MoveProducts"
                   asp-route-id="@Model.Id">
                    Urunleri baska kategoriye tasi
                </a>

                <a class="btn btn-outline-secondary ms-2"
                   asp-area="Admin"
                   asp-controller="Products"
                   asp-action="Index">
                    Urunlere git
                </a>
            }
            else
            {
                <div class="alert alert-danger mb-3">
                    Bu islem geri alinamaz. Silmek istediginden emin misin?
                </div>

                <form asp-area="Admin" asp-controller="Categories" asp-action="Delete" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger">Sil</button>
                        <a class="btn btn-outline-secondary" asp-area="Admin" asp-controller="Categories" asp-action="Index">Iptal</a>
                    </div>
                </form>
            }
        </div>
    </div>
    </div>
    </div>
</div>
